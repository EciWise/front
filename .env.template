# Template .env for ECIWISE-Front server
# Copy to .env and edit values for your environment.

# Port used by the SSR Node server and by `npm start` (ng serve dev-server)
PORT=4000

# Base URL of the backend auth/API service that the frontend will call
# Example: http://localhost:3001 or http://api.example.com
AUTH_SERVICE=http://localhost:3001

# Base URL of the ECIWISE-STUDY service (flashcards / spaced repetition)
# Consumed at runtime via assets/env.json -> studyApiUrl (default http://localhost:8082)
STUDY_SERVICE=http://localhost:8082

# Base URL of the talk service (chats / groups / messaging)
# Consumed at runtime via assets/env.json -> talkApiUrl (default http://localhost:3003)
TALK_SERVICE=http://localhost:3003
# WebSocket (STOMP) endpoint of the talk service
# Consumed at runtime via assets/env.json -> talkWsUrl (default ws://localhost:3003/ws/chat)
TALK_WS=ws://localhost:3003/ws/chat

# Base URL of the ECIWISE-TODO service (tasks / planner)
# Consumed at runtime via assets/env.json -> todoApiUrl (default http://localhost:8083)
TODO_SERVICE=http://localhost:8083

# WebSocket endpoint of the Asclepio game server (Go, real-time multiplayer)
# Consumed at runtime via assets/env.json -> gameWsUrl (default ws://localhost:3002/ws/game)
GAME_WS=ws://localhost:3002/ws/game

# Base URLs of los servicios de prediccion IA
# Consumed at runtime via assets/env.json -> performanceApiUrl / dropoutApiUrl
PERFORMANCE_SERVICE=http://localhost:8001
DROPOUT_SERVICE=http://localhost:8002

# Servicios adicionales del stack completo
# Consumed at runtime via assets/env.json -> aiApiUrl / communityApiUrl
AI_SERVICE=http://localhost:3008
COMMUNITY_SERVICE=http://localhost:3009

# Base URL of the notifications service (NestJS, push notifications / bell)
# Consumed at runtime via assets/env.json -> notificationsApiUrl (default http://localhost:3004)
NOTIFICATIONS_SERVICE=http://localhost:3004

# Base URL of the materials service (NestJS, file uploads / PDF)
# Consumed at runtime via assets/env.json -> materialsApiUrl (default http://localhost:3005)
MATERIALS_SERVICE=http://localhost:3005

# Base URL of the tutoring service (NestJS, tutorias / disponibilidad / reservas)
# Consumed at runtime via assets/env.json -> tutoringApiUrl (default http://localhost:3006)
TUTORING_SERVICE=http://localhost:3006

# Base URL of the gamification service (.NET, ranking / logros)
# Consumed at runtime via assets/env.json -> gamificationApiUrl (default http://localhost:8084)
GAMIFICATION_SERVICE=http://localhost:8084
